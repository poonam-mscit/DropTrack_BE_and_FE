{
  "name": "droptrack",
  "private": true,
  "version": "0.0.1",
  "description": "DropTrack — AI-powered leaflet distribution platform (Australia)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:push": "pnpm --filter @droptrack/db push",
    "db:studio": "pnpm --filter @droptrack/db studio",
    "db:seed": "pnpm --filter @droptrack/db seed",
    "db:init": "pnpm --filter @droptrack/db init"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
