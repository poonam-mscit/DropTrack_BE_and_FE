# DropTrack — root env template. Copy to .env and fill in.

# Database (local Docker default; override per-env)
DATABASE_URL=postgres://postgres:dev@localhost:5432/droptrack

# AWS
AWS_REGION=ap-southeast-2
AWS_BEDROCK_REGION=ap-southeast-2

# Cognito (fill after Phase 1)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=ap-southeast-2

# S3
S3_BUCKET=droptrack-uploads

# Stripe (test keys to start)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Mapbox
MAPBOX_PUBLIC_TOKEN=pk.
MAPBOX_SECRET_TOKEN=sk.

# Bedrock / Mistral
BEDROCK_MODEL_ID=mistral.mistral-small-3-0-instruct

# Email (SES; verified sender domain)
SES_FROM_EMAIL=welcome@droptrack.au
