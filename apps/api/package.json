{
  "name": "@droptrack/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "cognito:seed": "node --env-file=../../.env dist/auth/cognito-seed-users.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1045.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1045.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-sesv2": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@droptrack/db": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^11.1.20",
    "@nestjs/websockets": "^11.1.20",
    "aws-jwt-verify": "^5.1.1",
    "drizzle-orm": "^0.36.0",
    "express": "^5.2.1",
    "nestjs-zod": "^5.3.0",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@aws-sdk/client-bedrock": "^3.1046.0",
    "@nestjs/cli": "^10.4.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}