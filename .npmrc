# pnpm needs to hoist Expo / React-Native packages out of the .pnpm store and
# into apps/dropper/node_modules so Metro's resolver can find them. Without
# this, you get "Unable to resolve module expo-modules-core" when bundling
# the Expo app from a pnpm monorepo.
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=@expo/*
public-hoist-pattern[]=@react-native/*
public-hoist-pattern[]=@react-native-community/*
public-hoist-pattern[]=@react-navigation/*
public-hoist-pattern[]=react-native
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom

# Drizzle / shared workspace deps
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=true
